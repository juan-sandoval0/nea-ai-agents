# OpenAI
OPENAI_API_KEY=your_openai_api_key

# Anthropic (Claude - used for outreach generation)
# Get your key from: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key

# Harmonic.ai API (company intelligence)
# Get your key from: https://console.harmonic.ai/docs/dashboard
HARMONIC_API_KEY=your_harmonic_api_key

# Tavily API (website intelligence - FREE tier: 1,000 credits/month)
# Get your key from: https://tavily.com/
TAVILY_API_KEY=your_tavily_api_key

# The Swarm API (founder profile intelligence)
# Get your key from: https://theswarm.com
SWARM_API_KEY=your_swarm_api_key

# Parallel Search API (news research)
# Get your key from: https://parallel.ai/
PARALLEL_API_KEY=your_parallel_api_key

# LangSmith Tracing (optional)
LANGSMITH_API_KEY=your_langsmith_api_key
LANGSMITH_TRACING=false
LANGSMITH_PROJECT=meeting-briefing-mvp

# Legacy LangChain tracing vars (kept for compatibility)
LANGCHAIN_API_KEY=your_langsmith_api_key
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT=nea-ai-agents
