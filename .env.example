# OpenAI
OPENAI_API_KEY=your_openai_api_key

# Anthropic (Claude - used for outreach generation)
# Get your key from: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key

# Harmonic.ai API (company intelligence)
# Get your key from: https://console.harmonic.ai/docs/dashboard
HARMONIC_API_KEY=your_harmonic_api_key

# Tavily API (website intelligence - FREE tier: 1,000 credits/month)
# Get your key from: https://tavily.com/
TAVILY_API_KEY=your_tavily_api_key

# The Swarm API (founder profile intelligence)
# Get your key from: https://theswarm.com
SWARM_API_KEY=your_swarm_api_key

# Parallel Search API (news research)
# Get your key from: https://parallel.ai/
PARALLEL_API_KEY=your_parallel_api_key

# LangSmith Tracing (optional)
LANGSMITH_API_KEY=your_langsmith_api_key
LANGSMITH_TRACING=false
LANGSMITH_PROJECT=meeting-briefing-mvp

# Legacy LangChain tracing vars (kept for compatibility)
LANGCHAIN_API_KEY=your_langsmith_api_key
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT=nea-ai-agents

# Supabase (for app-facing reads / writes)
# Get these from: https://supabase.com/dashboard/project/<your-project>/settings/api
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key

# CORS allowlist — comma-separated origins allowed to call this API.
# Production must set this explicitly; defaults to localhost for dev.
ALLOWED_ORIGINS=http://localhost:3000

# Interim shared-secret guard for write endpoints (POST/DELETE/PUT/PATCH on /api/*).
# Clients must send the same value as the X-NEA-Key header.
# Leave unset locally to disable. Replaced by real auth (Clerk/Auth0) in Phase 3.
NEA_API_KEY=generate-a-random-32+char-string

# Upstash Redis (for rate limiting)
# Get these from: https://console.upstash.com/
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-redis-token

# =============================================================================
# PHASE 3 FEATURE FLAGS
# =============================================================================

# Structured LLM output (Phase 3.4)
# When true, uses Claude's with_structured_output() instead of regex parsing
# for briefing sections. More reliable but slightly higher latency.
USE_STRUCTURED_BRIEFING=false

# Clerk authentication (Phase 3.1)
# When true, requires Clerk JWT tokens instead of X-NEA-Key header.
# Requires CLERK_* env vars to be set.
USE_CLERK_AUTH=false

# Clerk credentials (required when USE_CLERK_AUTH=true)
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxx
# CLERK_SECRET_KEY=sk_test_xxx
# CLERK_JWKS_URL=https://your-clerk-domain.clerk.accounts.dev/.well-known/jwks.json
