{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "buildCommand": "cd frontend && npm run build",
  "devCommand": "cd frontend && npm run dev",
  "installCommand": "cd frontend && npm install",
  "outputDirectory": "frontend/.next",
  "functions": {
    "api/py/briefing.py": {
      "maxDuration": 300,
      "includeFiles": "{core,tools,agents,services}/**"
    },
    "api/py/briefings.py": {
      "maxDuration": 60,
      "includeFiles": "{core,tools,agents,services}/**"
    },
    "api/py/digest.py": {
      "maxDuration": 120,
      "includeFiles": "{core,tools,agents,services}/**"
    },
    "api/py/news_status.py": {
      "maxDuration": 30,
      "includeFiles": "{core,services}/**"
    },
    "api/py/outreach.py": {
      "maxDuration": 300,
      "includeFiles": "{core,tools,agents,services}/**"
    },
    "api/py/outreach-feedback.py": {
      "maxDuration": 60,
      "includeFiles": "{core,services}/**"
    }
  },
  "rewrites": [
    { "source": "/api/briefing", "destination": "/api/py/briefing" },
    { "source": "/api/briefings", "destination": "/api/py/briefings" },
    { "source": "/api/briefings/:id", "destination": "/api/py/briefings/:id" },
    { "source": "/api/digest/weekly", "destination": "/api/py/digest" },
    { "source": "/api/news/status", "destination": "/api/py/news_status" },
    { "source": "/api/news/status/:job_id", "destination": "/api/py/news_status/:job_id" },
    { "source": "/api/outreach", "destination": "/api/py/outreach" },
    { "source": "/api/outreach/feedback", "destination": "/api/py/outreach-feedback" }
  ]
}
